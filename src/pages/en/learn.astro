---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Learn – Helsinki DDC" lang="en" activePage="Learn">
  <div class="page-header">
    <div class="container">
      <h1>LEARN DDC</h1>
      <p>Videos, guides, and rules</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <h2 class="section-title">VIDEOS</h2>
      <div class="content-grid">
        <div class="card">
          <h3>How to play DDC (2024)</h3>
          <p>
            <a href="https://www.youtube.com/watch?v=FH4yeOa7Lzg">A DDC clinic</a>
            given by Conrad Damon at the European Championships 2024 in Berlin.
            Great introduction to the details of the sport.
          </p>
        </div>
        <div class="card">
          <h3>DDC tips for beginners</h3>
          <p>
            Scott Zimmerman's videos for beginners:
            <a href="https://www.youtube.com/watch?v=QJugKDRZ4nQ">part one</a> and
            <a href="https://www.youtube.com/watch?v=v1q7CG1LOaE">part two</a>.
          </p>
        </div>
        <div class="card">
          <h3>Helsinki DDC YouTube</h3>
          <p>
            Check out our
            <a href="https://www.youtube.com/channel/UCfI8Ze9_RgiuICUe64Xuuag">YouTube channel</a>
            and this
            <a href="https://www.youtube.com/playlist?list=PLWAJkuP_G4rAnqwuhIUDcf2YSWD0rtBQs">playlist</a>.
          </p>
        </div>
        <div class="card">
          <h3>Guides &amp; Analysis</h3>
          <p>
            Conrad Damon's <a href="https://doubledisccourt.com/">website</a>
            has an extensive collection of guides, videos, and more.
          </p>
        </div>
      </div>

      <h2 class="section-title mt-xl">RULES</h2>
      <div class="card">
        <ul class="link-list">
          <li>
            <a href="https://wfdf.sport/wp-content/uploads/2020/07/wfdf_rulebook_article_ii-2016.pdf">DDC rules in English</a>
            (WFDF 2016)
          </li>
          <li>
            <a href="/Tuplakiekko_2016.pdf">DDC rules in Finnish</a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
