---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Helsinki DDC – Double Disc Court in Finland" lang="en" activePage="Home">
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/ddc_in_kapyla.jpg');"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <img src="/HKI_DDC.png" alt="Helsinki DDC" class="hero-logo" />
      <h1>DOUBLE DISC COURT IN FINLAND</h1>
      <p class="tagline">Tuplakiekko &mdash; Helsinki, Finland</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="weekly-highlight">
        <div>
          <h2>WEEKLY PICK-UP GAMES</h2>
          <p>
            We play every week all around the year on <strong>Tuesdays around 6 pm</strong>.
            Place and exact time is confirmed at our Signal group.
            Contact Heikki (<a href="mailto:hw@iki.fi">hw@iki.fi</a>) if you wish to join.
          </p>
          <p><em>No previous experience necessary</em> &ndash; just show up if you are interested in trying the sport!</p>
        </div>
      </div>

      <h2 class="section-title">2026 TOURNAMENT CALENDAR</h2>

      <ul class="event-list">
        <li class="event-item">
          <span class="event-date">FEB 7</span>
          <div class="event-info">
            <h3>Helsinki Winter Tournament</h3>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date">MAY 9</span>
          <div class="event-info">
            <h3>Iloranta Open</h3>
            <p>More info: <a href="https://iloranta.fi">iloranta.fi</a></p>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date event-tba">June</span>
          <div class="event-info">
            <h3>Doubles Tournament</h3>
            <p class="event-tba">Date to be announced</p>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date">JUL 25–26</span>
          <div class="event-info">
            <h3>DDC European Open</h3>
            <p>Helsinki</p>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date event-tba">August</span>
          <div class="event-info">
            <h3>Overall National Championships</h3>
            <p class="event-tba">Date to be announced</p>
          </div>
        </li>
      </ul>

      <p class="mt-lg text-muted">
        Tournament results are available at the <a href="https://doubledisccourt.com/results/">global DDC website</a>.
      </p>
    </div>
  </section>
</Layout>
