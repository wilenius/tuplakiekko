---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oppiminen – Helsinki DDC" lang="fi" activePage="Oppiminen">
  <div class="page-header">
    <div class="container">
      <h1>OPPIMINEN</h1>
      <p>Videoita, oppaita ja s&auml;&auml;nt&ouml;j&auml;</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <h2 class="section-title">VIDEOT</h2>
      <div class="content-grid">
        <div class="card">
          <h3>DDC-klinikka (2024)</h3>
          <p>
            Conrad Damon piti 2024 EM-kisojen yhteydess&auml;
            <a href="https://www.youtube.com/watch?v=FH4yeOa7Lzg">klinikan</a>,
            joka on hyv&auml; perehdytys lajin yksityiskohtiin. Video on my&ouml;s tekstitetty englanniksi.
          </p>
        </div>
        <div class="card">
          <h3>DDC tips for beginners</h3>
          <p>
            Scott Zimmermanin videot aloittelijoille:
            <a href="https://www.youtube.com/watch?v=QJugKDRZ4nQ">osa yksi</a> ja
            <a href="https://www.youtube.com/watch?v=v1q7CG1LOaE">osa kaksi</a>.
          </p>
        </div>
        <div class="card">
          <h3>Helsinki DDC YouTube</h3>
          <p>
            Helsinki DDC:ll&auml; on oma
            <a href="https://www.youtube.com/channel/UCfI8Ze9_RgiuICUe64Xuuag">YouTube-kanava</a>.
            Peleist&auml; on koottu my&ouml;s oma
            <a href="https://www.youtube.com/playlist?list=PLWAJkuP_G4rAnqwuhIUDcf2YSWD0rtBQs">soittolistansa</a>.
          </p>
        </div>
        <div class="card">
          <h3>Oppaat ja analyysit</h3>
          <p>
            Conrad Damonin <a href="https://doubledisccourt.com/">verkkosivuilla</a>
            on kattava kokoelma oppaita ja videoita.
          </p>
          <p class="mt-lg">
            Suomenkielinen <a href="/analyysi/">analyysi</a> kes&auml;n 2024 harjoitusottelusta
            (<a href="https://www.youtube.com/watch?v=IscXNk2ddUM">video</a>).
          </p>
        </div>
      </div>

      <h2 class="section-title mt-xl">SANASTO</h2>
      <div class="card">
        <p>
          Suomenkielinen <a href="/sanasto/">tuplakiekkosanasto</a> on hyv&auml; johdanto jargoniin.
          Alkuper&auml;inen englanninkielinen sanasto l&ouml;ytyy
          <a href="https://doubledisccourt.com/glossary.html">Conrad Damonin sivuilta</a>.
        </p>
      </div>

      <h2 class="section-title mt-xl">S&Auml;&Auml;NN&Ouml;T</h2>
      <div class="card">
        <ul class="link-list">
          <li>
            <a href="https://wfdf.sport/wp-content/uploads/2020/07/wfdf_rulebook_article_ii-2016.pdf">S&auml;&auml;nn&ouml;t englanniksi</a>
            (WFDF 2016)
          </li>
          <li>
            <a href="/Tuplakiekko_2016.pdf">Tuplakiekon s&auml;&auml;nn&ouml;t suomeksi</a>
          </li>
          <li>
            Hankalimpia s&auml;&auml;nt&ouml;pyk&auml;li&auml; on selitetty
            <a href="http://tinyurl.com/ddcknopit">erillisess&auml; dokumentissa</a>.
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
