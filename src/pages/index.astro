---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Helsinki DDC – Tuplakiekko Suomessa" lang="fi" activePage="Etusivu">
  <section class="hero">
    <div class="hero-bg" style="background-image: url('/ddc_in_kapyla.jpg');"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <img src="/HKI_DDC.png" alt="Helsinki DDC" class="hero-logo" />
      <h1>TUPLAKIEKKO SUOMESSA</h1>
      <p class="tagline">Double Disc Court &mdash; Helsinki, Finland</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="weekly-highlight">
        <div>
          <h2>VIIKOTTAISET PELIT</h2>
          <p>
            Helsinki DDC:ll&auml; on avoimet treenit aina <strong>tiistaisin n. klo 18:00</strong>, ymp&auml;ri vuoden.
            Paikka ja tarkka aika sovitaan viikottain Signal-ryhm&auml;ss&auml;mme.
            Ota yhteytt&auml; Heikkiin (<a href="mailto:hw@iki.fi">hw@iki.fi</a>), jos haluat liitty&auml; tai tulla kokeilemaan.
          </p>
          <p><em>Aikaisempi kokemus ei ole v&auml;ltt&auml;m&auml;t&ouml;nt&auml;</em> &ndash; voit tulla vain paikalle, jos haluat kokeilla lajia!</p>
        </div>
      </div>

      <h2 class="section-title">KISAKALENTERI 2026</h2>

      <ul class="event-list">
        <li class="event-item">
          <span class="event-date">7.2.</span>
          <div class="event-info">
            <h3>Helsingin talviturnaus</h3>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date">9.5.</span>
          <div class="event-info">
            <h3>Iloranta Open</h3>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date event-tba">Kes&auml;kuu</span>
          <div class="event-info">
            <h3>Pariturnaus</h3>
            <p class="event-tba">P&auml;iv&auml;m&auml;&auml;r&auml; vahvistetaan my&ouml;hemmin</p>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date">25.–26.7.</span>
          <div class="event-info">
            <h3>DDC European Open</h3>
            <p>Helsinki</p>
          </div>
        </li>
        <li class="event-item">
          <span class="event-date event-tba">Elokuu</span>
          <div class="event-info">
            <h3>Kentt&auml;lajien SM-kisat</h3>
            <p class="event-tba">P&auml;iv&auml;m&auml;&auml;r&auml; vahvistetaan my&ouml;hemmin</p>
          </div>
        </li>
      </ul>

      <p class="mt-lg text-muted">
        Turnaustulokset l&ouml;ytyv&auml;t <a href="https://doubledisccourt.com/results/">maailmanlaajuiselta DDC-verkkosivulta</a>.
      </p>
    </div>
  </section>
</Layout>
