<Layout title="Otteluanalyysi 10.7.2024 – Helsinki DDC" lang="fi" activePage="">
  <div class="page-header">
    <div class="container">
      <h1>OTTELUANALYYSI 10.7.2024</h1>
      <p>HW &amp; TY vs MS &amp; TK</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <a href="/oppi/" class="back-link">&larr; Takaisin</a>

      <div class="card mb-lg">
        <p>
          <strong>Tallenne:</strong>
          <a href="https://www.youtube.com/watch?v=IscXNk2ddUM">YouTube</a>
        </p>
        <h3 class="mt-lg">Selitys</h3>
        <ul style="margin-top: 0.5rem; padding-left: 1.2rem;">
          <li><strong>luovutus</strong> = kiekko, joka olisi ollut mahdollista pelata jotenkin, mutta ei pelattu</li>
          <li><strong>voittoheitto</strong> = kiekko, jota ei ole mahdollista pelata tai saada kiinni</li>
          <li><strong>soolopoltto</strong> = polttoheitto ilman tuplatilannetta</li>
          <li><strong>offaus</strong> = nopea poisheitto tuplatilanteessa</li>
        </ul>
      </div>

      {/* Era 1 */}
      <h2 class="section-title">1. ER&Auml;</h2>
      <div class="table-wrap mb-lg">
        <table class="styled-table">
          <thead><tr><th>Mitä</th><th>HW</th><th>TY</th><th>MS</th><th>TK</th></tr></thead>
          <tbody>
            {era1Stats.map(r => (
              <tr><td>{r.what}</td><td>{r.hw}</td><td>{r.ty}</td><td>{r.ms}</td><td>{r.tk}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <details class="mb-lg">
        <summary style="cursor:pointer; font-weight:600; margin-bottom:0.5rem;">Pelitapahtumat</summary>
        <div class="table-wrap">
          <table class="styled-table">
            <thead><tr><th>Aika</th><th>Tapahtuma</th></tr></thead>
            <tbody>
              {era1Events.map(e => (
                <tr><td>{e.time}</td><td>{e.event}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>

      {/* Era 2 */}
      <h2 class="section-title">2. ER&Auml;</h2>
      <div class="table-wrap mb-lg">
        <table class="styled-table">
          <thead><tr><th>Mitä</th><th>HW</th><th>TY</th><th>MS</th><th>TK</th></tr></thead>
          <tbody>
            {era2Stats.map(r => (
              <tr><td>{r.what}</td><td>{r.hw}</td><td>{r.ty}</td><td>{r.ms}</td><td>{r.tk}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <details class="mb-lg">
        <summary style="cursor:pointer; font-weight:600; margin-bottom:0.5rem;">Pelitapahtumat</summary>
        <div class="table-wrap">
          <table class="styled-table">
            <thead><tr><th>Aika</th><th>Tapahtuma</th></tr></thead>
            <tbody>
              {era2Events.map(e => (
                <tr><td>{e.time}</td><td>{e.event}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>

      {/* Era 3 */}
      <h2 class="section-title">3. ER&Auml;</h2>
      <div class="table-wrap mb-lg">
        <table class="styled-table">
          <thead><tr><th>Mitä</th><th>HW</th><th>TY</th><th>MS</th><th>TK</th></tr></thead>
          <tbody>
            {era3Stats.map(r => (
              <tr><td>{r.what}</td><td>{r.hw}</td><td>{r.ty}</td><td>{r.ms}</td><td>{r.tk}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <details class="mb-lg">
        <summary style="cursor:pointer; font-weight:600; margin-bottom:0.5rem;">Pelitapahtumat</summary>
        <div class="table-wrap">
          <table class="styled-table">
            <thead><tr><th>Aika</th><th>Tapahtuma</th></tr></thead>
            <tbody>
              {era3Events.map(e => (
                <tr><td>{e.time}</td><td>{e.event}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </details>

      {/* Summary */}
      <h2 class="section-title">YHTEENVETO</h2>
      <div class="table-wrap mb-lg">
        <table class="styled-table">
          <thead><tr><th>Mitä</th><th>HW</th><th>TY</th><th>MS</th><th>TK</th></tr></thead>
          <tbody>
            {totalStats.map(r => (
              <tr><td><strong>{r.what}</strong></td><td>{r.hw}</td><td>{r.ty}</td><td>{r.ms}</td><td>{r.tk}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="table-wrap mb-lg">
        <table class="styled-table">
          <thead><tr><th>Mitä</th><th>HW</th><th>TY</th><th>MS</th><th>TK</th></tr></thead>
          <tbody>
            {summaryStats.map(r => (
              <tr><td><strong>{r.what}</strong></td><td>{r.hw}</td><td>{r.ty}</td><td>{r.ms}</td><td>{r.tk}</td></tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2 class="section-title">HUOMIOITA</h2>
      <div class="card">
        <ul style="padding-left: 1.2rem;">
          {notes.map(n => <li style="margin-bottom: 0.5rem;">{n}</li>)}
        </ul>
      </div>
    </div>
  </section>
</Layout>
